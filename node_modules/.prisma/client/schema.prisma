// Roop Rang - Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(150)
  password  String   @db.VarChar(255)
  role      Role     @default(ADMIN)
  avatar    String?  @db.VarChar(255)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model User {
  id         Int             @id @default(autoincrement())
  name       String          @db.VarChar(100)
  email      String          @unique @db.VarChar(150)
  phone      String?         @db.VarChar(20)
  password   String?         @db.VarChar(255)
  status     Status          @default(ACTIVE)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  isVerified Boolean         @default(false)
  inquiries  Inquiry[]
  supports   SupportTicket[]

  @@map("users")
}

model EmailOTP {
  id        Int      @id @default(autoincrement())
  email     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(120)
  description String?   @db.Text
  image       String?   @db.VarChar(255)
  status      Status    @default(ACTIVE)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("categories")
}

model Product {
  id             Int            @id @default(autoincrement())
  name           String         @db.VarChar(200)
  slug           String         @unique @db.VarChar(220)
  sku            String         @unique @db.VarChar(100)
  brand          String?        @db.VarChar(100)
  description    String         @db.Text
  shortDesc      String?        @db.VarChar(300)
  mrp            Decimal        @db.Decimal(10, 2)
  sellingPrice   Decimal        @db.Decimal(10, 2)
  discount       Int            @default(0)
  stock          Int            @default(0)
  stockStatus    StockStatus    @default(IN_STOCK)
  categoryId     Int
  category       Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  isFeatured     Boolean        @default(false)
  isNewArrival   Boolean        @default(false)
  isBestSeller   Boolean        @default(false)
  isOffer        Boolean        @default(false)
  status         Status         @default(ACTIVE)
  seoTitle       String?        @db.VarChar(200)
  seoDescription String?        @db.VarChar(300)
  viewCount      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  images         ProductImage[]

  @@index([categoryId])
  @@index([slug])
  @@map("products")
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String   @db.VarChar(255)
  alt       String?  @db.VarChar(150)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("product_images")
}

model Offer {
  id           Int          @id @default(autoincrement())
  name         String       @db.VarChar(150)
  slug         String       @unique @db.VarChar(170)
  description  String?      @db.Text
  bannerImage  String?      @db.VarChar(255)
  discount     Int          @default(0)
  discountType DiscountType @default(PERCENTAGE)
  startDate    DateTime
  endDate      DateTime
  status       Status       @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("offers")
}

model Inquiry {
  id        Int           @id @default(autoincrement())
  name      String        @db.VarChar(100)
  email     String        @db.VarChar(150)
  mobile    String        @db.VarChar(20)
  product   String?       @db.VarChar(200)
  productId Int?
  message   String        @db.Text
  status    InquiryStatus @default(NEW)
  replied   Boolean       @default(false)
  reply     String?       @db.Text
  userId    Int?
  user      User?         @relation(fields: [userId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("inquiries")
}

model Contact {
  id        Int           @id @default(autoincrement())
  name      String        @db.VarChar(100)
  email     String        @db.VarChar(150)
  phone     String?       @db.VarChar(20)
  subject   String?       @db.VarChar(200)
  message   String        @db.Text
  status    ContactStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("contacts")
}

model SupportTicket {
  id        Int            @id @default(autoincrement())
  ticketNo  String         @unique @db.VarChar(50)
  name      String         @db.VarChar(100)
  email     String         @db.VarChar(150)
  subject   String         @db.VarChar(200)
  message   String         @db.Text
  priority  TicketPriority @default(MEDIUM)
  status    TicketStatus   @default(OPEN)
  reply     String?        @db.Text
  userId    Int?
  user      User?          @relation(fields: [userId], references: [id])
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("support_tickets")
}

model PrivacyPolicy {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(200)
  slug      String   @unique @db.VarChar(220)
  content   String   @db.Text
  version   String   @default("1.0") @db.VarChar(20)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("privacy_policy")
}

model TermsCondition {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(200)
  slug      String   @unique @db.VarChar(220)
  content   String   @db.Text
  version   String   @default("1.0") @db.VarChar(20)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("terms_conditions")
}

model WebsiteSetting {
  id           Int     @id @default(autoincrement())
  supportEmail String
  supportPhone String
  address      String
  currency     String
  taxRate      Float
  facebook     String?
  instagram    String?
  twitter      String?
  logo         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HeroBanner {
  id        Int      @id @default(autoincrement())
  image     String
  badgeText String?
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Visitor {
  id        Int      @id @default(autoincrement())
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum Status {
  ACTIVE
  INACTIVE
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  LOW_STOCK
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum ContactStatus {
  PENDING
  COMPLETED
  ARCHIVED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
